[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/AdhiAdithyan/CallQTV.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[user]
	name = Adhi Adithyan
	email = adhiadithyan@github.com
[branch "main"]
	remote = origin
	merge = refs/heads/main
